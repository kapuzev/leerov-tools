#!/bin/bash
CURRENT_DIR=$(pwd)
SCRIPT_DIR="$HOME/leerov-tools"
cd "$SCRIPT_DIR" || return

set +m

# Запускаем подсчёт в фоне, но записываем результаты во временный файл
(
    # Считаем goinfre
    if [ -d "/opt/goinfre/$(whoami)" ]; then
        goinfre_size=$(du -sh /opt/goinfre/$(whoami) 2>/dev/null | cut -f1)
        disk_info=$(df -h /opt/goinfre/$(whoami) 2>/dev/null | tail -1 | awk '{print $3 " / " $4 " / " $2 " (" $5 ")"}' 2>/dev/null)
    else
        goinfre_size="N/A"
        disk_info="N/A"
    fi
    
    # Считаем домашнюю папку
    home_size=$(du -sh $HOME 2>/dev/null | cut -f1)
    home_max=$(df -h $HOME 2>/dev/null | tail -1 | awk '{print $2}')
    
    # Записываем в файл
    echo "GOINFRE_SIZE='$goinfre_size'" > /tmp/disk_vars_$$.tmp
    echo "DISK_INFO='$disk_info'" >> /tmp/disk_vars_$$.tmp
    echo "HOME_SIZE='$home_size'" >> /tmp/disk_vars_$$.tmp
    echo "HOME_MAX='$home_max'" >> /tmp/disk_vars_$$.tmp
    echo "CALC_DONE=1" >> /tmp/disk_vars_$$.tmp
) >/dev/null 2>&1 &

# Сохраняем PID
CALC_PID=$!

# Функция для загрузки переменных в текущую сессию
load_disk_vars() {
    local tmp_file="/tmp/disk_vars_$$.tmp"
    if [ -f "$tmp_file" ]; then
        source "$tmp_file"
        rm -f "$tmp_file"
        return 0
    fi
    return 1
}

# Проверка готовности
check_disk_vars() {
    if [ -f "/tmp/disk_vars_$$.tmp" ]; then
        load_disk_vars
        return 0
    fi
    return 1
}

# Функция для вывода информации о диске (после загрузки переменных)
show_disk_info() {
    # Цикл проверки готовности (ждём до 2 секунд)
    local max_wait=20  # 20 попыток по 0.1 сек = 2 секунды
    local waited=0
    
    while [ $waited -lt $max_wait ]; do
        # Проверяем, загружены ли переменные
        if [ -n "$GOINFRE_SIZE" ] && [ -n "$HOME_SIZE" ]; then
            break
        fi
        
        # Проверяем, есть ли файл с результатами
        if [ -f "/tmp/disk_vars_$$.tmp" ]; then
            load_disk_vars
            if [ -n "$GOINFRE_SIZE" ] && [ -n "$HOME_SIZE" ]; then
                break
            fi
        fi
        
        sleep 0.1
        waited=$((waited + 1))
    done
    
    # Выводим информацию
    if [ -n "$GOINFRE_SIZE" ] && [ -n "$DISK_INFO" ] && [ -n "$HOME_SIZE" ] && [ -n "$HOME_MAX" ]; then
        if [ "$GOINFRE_SIZE" != "N/A" ]; then
            echo "📁 Вес вашей папки Goinfre: $GOINFRE_SIZE"
            echo "💾 Диск: $DISK_INFO"
            echo ""
        fi
        echo "📁 Домашняя папка: $HOME_SIZE / $HOME_MAX"
    else
        echo "⏳ Данные ещё не загружены. Попробуйте позже."
    fi
}


